<?php

$name = "";
$email = "";
$course = "";
$message = "";

if($_SERVER["REQUEST_METHOD"] == "POST")
{
    $name = $_POST["name"];
    $email = $_POST["email"];
    $course = $_POST["course"];

    // Store data in a text file
    $data = "Name: ".$name.
            " | Email: ".$email.
            " | Course: ".$course."\n";

    file_put_contents("studentdata.txt",
                      $data,
                      FILE_APPEND);

    $message = "Data Stored Successfully!";
}
?>

