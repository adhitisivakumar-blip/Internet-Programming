<?php

$message = "";
$opinion = "";

if($_SERVER["REQUEST_METHOD"] == "POST")
{
    $opinion = $_POST["opinion"];

    file_put_contents(
        "opinions.txt",
        $opinion . "\n",
        FILE_APPEND
    );

    $message = "Opinion Submitted Successfully!";
}

$opinions = [];

if(file_exists("opinions.txt"))
{
    $opinions = file("opinions.txt",
                     FILE_IGNORE_NEW_LINES);
}
