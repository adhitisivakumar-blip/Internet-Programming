<?php

$message = "";

if(isset($_POST['bookappointment']))
{
    $patient = $_POST['patient'];
    $doctor = $_POST['doctor'];
    $department = $_POST['department'];
    $date = $_POST['date'];
    $time = $_POST['time'];

    $data = $patient."|".$doctor."|".$department."|".$date."|".$time."\n";

    file_put_contents(
        "hospitalappointments.txt",
        $data,
        FILE_APPEND
    );

    $message = "Appointment Booked Successfully!";
}

$appointments = [];

if(file_exists("hospitalappointments.txt"))
{
    $appointments = file(
        "hospitalappointments.txt",
        FILE_IGNORE_NEW_LINES
    );
}

?>

