<?php

$message = "";

if(isset($_POST['bookappointment']))
{
    $name = $_POST['name'];
    $service = $_POST['service'];
    $date = $_POST['date'];
    $time = $_POST['time'];
    $phone = $_POST['phone'];

    $data = $name."|".$service."|".$date."|".$time."|".$phone."\n";

    file_put_contents(
        "appointments.txt",
        $data,
        FILE_APPEND
    );

    $message = "Appointment Booked Successfully!";
}

$appointments = [];

if(file_exists("appointments.txt"))
{
    $appointments = file(
        "appointments.txt",
        FILE_IGNORE_NEW_LINES
    );
}

