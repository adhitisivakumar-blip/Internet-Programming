<?php

$message = "";

if(isset($_POST['bookticket']))
{
    $name = $_POST['name'];
    $source = $_POST['source'];
    $destination = $_POST['destination'];
    $journeydate = $_POST['journeydate'];
    $seats = $_POST['seats'];

    $data = $name."|".$source."|".$destination."|".$journeydate."|".$seats."\n";

    file_put_contents(
        "tickets.txt",
        $data,
        FILE_APPEND
    );

    $message = "Bus Ticket Booked Successfully!";
}

$bookings = [];

if(file_exists("tickets.txt"))
{
    $bookings = file(
        "tickets.txt",
        FILE_IGNORE_NEW_LINES
    );
}

