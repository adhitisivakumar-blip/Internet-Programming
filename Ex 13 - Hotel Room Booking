<?php

$message = "";

if(isset($_POST['bookroom']))
{
    $name = $_POST['name'];
    $email = $_POST['email'];
    $room = $_POST['room'];
    $checkin = $_POST['checkin'];
    $checkout = $_POST['checkout'];

    $data = $name."|".$email."|".$room."|".$checkin."|".$checkout."\n";

    file_put_contents(
        "bookings.txt",
        $data,
        FILE_APPEND
    );

    $message = "Room Booked Successfully!";
}

$bookings = [];

if(file_exists("bookings.txt"))
{
    $bookings = file(
        "bookings.txt",
        FILE_IGNORE_NEW_LINES
    );
}

