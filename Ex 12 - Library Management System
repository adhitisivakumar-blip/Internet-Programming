<?php

$message = "";

if(isset($_POST['addbook']))
{
    $bookname = $_POST['bookname'];
    $author = $_POST['author'];
    $category = $_POST['category'];

    $data = $bookname . "|" . $author . "|" . $category . "\n";

    file_put_contents(
        "books.txt",
        $data,
        FILE_APPEND
    );

    $message = "Book Added Successfully!";
}

$books = [];

if(file_exists("books.txt"))
{
    $books = file(
        "books.txt",
        FILE_IGNORE_NEW_LINES
    );
}

